# ─── SSPA VSO — Variables de entorno ─────────────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env con el token real a un repositorio.

# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=8517973767:AAGU0xrCLMr7x2YbWGaE2InRPPyuYH_GFD8

# Modelo Ollama a usar.
# Recomendados para CPU Ryzen 5 + 16 GB RAM:
#   qwen2:1.5b   → ~2.5 GB RAM, más rápido  ✅ (por defecto)
#   phi3:mini    → ~2.3 GB RAM, buen español
#   llama3.2:3b  → ~3.5 GB RAM, mejor calidad pero más lento
#   llama3:8b    → ~6 GB RAM, lento en CPU  ⚠ no recomendado
MODEL_NAME=qwen2:1.5b

# Modelo Whisper para transcripción de voz
# tiny  → ~40 MB RAM, ~10 seg por audio    (si el hardware es muy limitado)
# base  → ~75 MB RAM, ~20 seg, mejor español ✅ (por defecto)
# small → ~250 MB RAM, mejor calidad aún   (si tenés RAM de sobra)
WHISPER_MODEL=base
