# ─── SSPA VSO — Variables de entorno ─────────────────────────────────────────

# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=TU_TOKEN_AQUI

# Modelo LLM para Ollama
# qwen2:1.5b  → ~2.5 GB RAM, más rápido  ✅ (por defecto)
# phi3:mini   → ~2.3 GB RAM
# llama3.2:3b → ~3.5 GB RAM, mejor calidad
MODEL_NAME=qwen2:1.5b

# Modelo Whisper para transcripción de voz
# tiny  → ~40 MB RAM, ~10 seg por audio    (si el hardware es muy limitado)
# base  → ~75 MB RAM, ~20 seg, mejor español ✅ (por defecto)
# small → ~250 MB RAM, mejor calidad aún   (si tenés RAM de sobra)
WHISPER_MODEL=base
